
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isTeacher() {
      return hasRole('teacher');
    }

    function isAccountant() {
      return hasRole('accountant');
    }

    function isStudent() {
      return hasRole('student');
    }

    function isParent() {
      return hasRole('parent');
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == userId;
    }

    match /studentProfiles/{profileId} {
      allow read: if isSignedIn() && (
        isTeacher() || isAdmin() || isAccountant() || 
        (isStudent() && resource.data.userId == request.auth.uid) ||
        (isParent() && resource.data.parentId == request.auth.uid)
      );
      allow create, update, delete: if isAdmin() || isTeacher();
    }

    match /grades/{gradeId} {
      allow read: if isSignedIn() && (
        isTeacher() || isAdmin() ||
        (isStudent() && resource.data.studentId == request.auth.uid) ||
        (isParent() && resource.data.studentId == request.auth.uid)
      );
      allow create, update, delete: if isTeacher() || isAdmin();
    }

    match /assignments/{assignmentId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isTeacher() || isAdmin();
    }

    match /submissions/{submissionId} {
      allow read: if isSignedIn() && (isTeacher() || isAdmin() || (isStudent() && request.auth.uid == resource.data.studentId));
      allow create: if isStudent();
    }

    match /materials/{materialId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isTeacher() || isAdmin();
    }

    match /invoices/{invoiceId} {
      allow read: if isSignedIn() && (
        isAccountant() || isAdmin() || 
        (isParent() && resource.data.studentId == request.auth.uid) ||
        (isStudent() && resource.data.studentId == request.auth.uid)
      );
      allow create, update, delete: if isAccountant() || isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isSignedIn() && (
        resource.data.isPublic == true ||
        resource.data.senderId == request.auth.uid ||
        resource.data.recipientId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() && (
        (request.resource.data.isPublic == true && isAdmin()) ||
        (request.resource.data.isPublic != true)
      );
      allow update, delete: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.senderId);
    }
  }
}
